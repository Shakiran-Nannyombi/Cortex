# Cortex Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Flask Configuration
# ============================================
FLASK_ENV=production

# Pre-generated secret keys (safe for demo, regenerate for production)
SECRET_KEY=a7f3c9e2b1d4f6a8c5e7b9d1f3a5c7e9b1d3f5a7c9e1b3d5f7a9c1e3f5a7c9
JWT_SECRET_KEY=b8g4d0f3e2c1a9b7d5f3e1c9a7b5d3f1e9c7a5b3d1f9e7c5a3b1d9f7e5c3a1

# ============================================
# DATABASE - PostgreSQL
# ============================================
# Docker Compose (local):
DATABASE_URL=postgresql://cortex:cortex@db:5432/cortex

# Heroku (auto-set, don't change):
# DATABASE_URL=postgresql://...

# ============================================
# CACHE - Redis
# ============================================
# Docker Compose (local):
REDIS_URL=redis://redis:6379/0

# Heroku (auto-set, don't change):
# REDIS_URL=redis://...

# ============================================
# FRONTEND - API URL
# ============================================
# Local development:
VITE_API_URL=http://localhost:5000

# Docker Compose:
# VITE_API_URL=http://backend:5000

# Heroku:
# VITE_API_URL=https://your-app-name.herokuapp.com

# ============================================
# OPTIONAL - Chatbot (OpenAI)
# ============================================
# Get API key from: https://platform.openai.com/api-keys
# Leave empty to disable chatbot
OPENAI_API_KEY=

# ============================================
# OPTIONAL - OCR (Document Text Extraction)
# ============================================
# Options: tesseract (default, local), gcp, aws, azure
# Tesseract is included in Docker image, no API needed
OCR_PROVIDER=tesseract

# For GCP Vision OCR (optional):
# GOOGLE_APPLICATION_CREDENTIALS_JSON=
# GOOGLE_CLOUD_PROJECT=

# ============================================
# OPTIONAL - Cloud Storage
# ============================================
# Options: local (default), gcs, s3, azure_blob
STORAGE_PROVIDER=local

# ============================================
# UPLOAD FOLDER
# ============================================
UPLOAD_FOLDER=/app/uploads

# ============================================
# QUICK START
# ============================================
# For Dock=/aper Demo (everything included):
#   docker-compose up -d
#   Access: http://localhost:3000
#   Login: demo@cortex.app / Demo@123
#
# For Heroku Deployment:
#   1. Create Heroku app
#   2. Set these env vars in Heroku dashboard
#   3. Connect GitHub and deploy
#   4. Access: https://your-app-name.herokuapp.com
#
# Optional Enhancements:
#   - Add OPENAI_API_KEY for chatbot
#   - Add GCP credentials for better OCR

