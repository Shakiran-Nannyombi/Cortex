# Cortex Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Flask Configuration
# ============================================
FLASK_ENV=development

# Generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-key-here

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-random-jwt-secret-key-here

# ============================================
# DATABASE - PostgreSQL
# ============================================
# Local development (Docker):
DATABASE_URL=postgresql://cortex:cortex@localhost:5432/cortex

# Production (Heroku/Cloud):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# CACHE - Redis
# ============================================
# Local development (Docker):
REDIS_URL=redis://localhost:6379/0

# Production (Heroku/Cloud):
# REDIS_URL=redis://user:password@host:6379/0

# ============================================
# OPTIONAL - Chatbot (OpenAI)
# ============================================
# Get API key from: https://platform.openai.com/api-keys
# Leave empty to disable chatbot
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# OPTIONAL - OCR (Document Text Extraction)
# ============================================
# Options: tesseract (default, local), gcp, aws, azure
# Tesseract is included in Docker image, no API needed
OCR_PROVIDER=tesseract

# For GCP Vision OCR:
# 1. Create GCP project: https://console.cloud.google.com
# 2. Enable Vision API
# 3. Create service account with Vision API access
# 4. Download JSON key and encode as base64:
#    cat service-account-key.json | base64 -w 0
# 5. Set the base64 string below:
GOOGLE_APPLICATION_CREDENTIALS_JSON=your-base64-encoded-gcp-credentials-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# For AWS Textract OCR:
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# For Azure Computer Vision OCR:
# AZURE_CV_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
# AZURE_CV_KEY=your-azure-cv-key

# ============================================
# OPTIONAL - Cloud Storage
# ============================================
# Options: local (default), gcs, s3, azure_blob
# Local storage uses Docker volumes, no API needed
STORAGE_PROVIDER=local

# For Google Cloud Storage:
# STORAGE_BUCKET=your-gcs-bucket-name

# For AWS S3:
# STORAGE_BUCKET=your-s3-bucket-name
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# For Azure Blob Storage:
# STORAGE_BUCKET=your-container-name
# AZURE_STORAGE_CONNECTION_STRING=your-connection-string

# ============================================
# FRONTEND - API URL
# ============================================
# Local development:
VITE_API_URL=http://localhost:5000

# Production:
# VITE_API_URL=https://api.yourdomain.com

# ============================================
# UPLOAD FOLDER
# ============================================
# Local development (Docker):
UPLOAD_FOLDER=/app/uploads

# ============================================
# QUICK START GUIDE
# ============================================
# 1. For Docker Demo (No APIs Required):
#    - Keep defaults for FLASK_ENV, DATABASE_URL, REDIS_URL
#    - Leave OPENAI_API_KEY empty
#    - Keep OCR_PROVIDER=tesseract
#    - Run: docker-compose up -d
#
# 2. To Add Chatbot (Optional):
#    - Get OpenAI API key: https://platform.openai.com/api-keys
#    - Set OPENAI_API_KEY=sk-...
#
# 3. To Add Better OCR (Optional):
#    - Set OCR_PROVIDER=gcp
#    - Get GCP credentials (see instructions above)
#    - Set GOOGLE_APPLICATION_CREDENTIALS_JSON
#
# 4. For Production Deployment:
#    - See DOCKER_DEPLOYMENT.md or HEROKU_DEPLOYMENT.md
#    - Generate new SECRET_KEY and JWT_SECRET_KEY
#    - Use cloud database and cache services
